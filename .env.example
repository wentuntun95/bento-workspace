# Supabase（公开可见，设计上安全，通过 RLS 保护数据）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI 对话（仅 server-side，BFF 代理，key 不暴露给前端）
# 默认使用 Google Gemini，也可换成 OpenAI / Claude 等（需改 route.ts）
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash   # 可选，默认 gemini-2.0-flash

# 旧版 MiniMax（已停用，保留仅供参考）
# MINIMAX_API_KEY=your_api_key
# MINIMAX_GROUP_ID=your_group_id

# Admin 审批功能（可选，用于账号申请审核）
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Supabase → Settings → API
# ADMIN_TOKEN=your_random_secret_token             # 自定义任意随机字符串
